# VirtualChemLab 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 应用配置 ====================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# JWT密钥 (生产环境必须修改！)
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# 开发者模式密钥哈希（运行 tools/setup_dev_key.py 生成，勿提交真实密钥）
DEVELOPER_KEY_HASH=your-developer-key-hash-here

# 教师模式密码哈希
TEACHER_PASSWORD_HASH=your-teacher-password-hash-here

# 许可证密钥
LICENSE_SECRET_KEY=your-license-secret-key-change-in-production

# Webhook密钥
WEBHOOK_SECRET=your-webhook-secret-here

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///data/virtualchemlab.db
DATABASE_POOL_SIZE=10

# ==================== Redis配置 (可选) ====================
REDIS_ENABLED=False
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== 性能配置 ====================
CACHE_ENABLED=True
CACHE_DEFAULT_TTL=300
CACHE_MAX_SIZE=1000

# ==================== 监控配置 ====================
MONITORING_ENABLED=True
PERFORMANCE_TRACKING=True

# ==================== API 密钥 ====================
# 区块链API密钥 (可选)
ETHERSCAN_API_KEY=your-etherscan-api-key-here

# 通知服务 (可选)
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ==================== 文件路径 ====================
TEMPLATES_DIR=assets/templates
KNOWLEDGE_DIR=assets/knowledge
USER_DATA_DIR=user_data
REPORTS_DIR=reports
VCL_JWT_SECRET=your_jwt_secret_here
VCL_ADMIN_SECRET_KEY=your_admin_secret_here
