{
    "app": {
        "environment": "production",
        "debug": false
    },
    "monitoring": {
        "log_level": "WARNING"
    },
    "performance": {
        "cache_enabled": true,
        "cache_type": "redis",
        "max_workers": 8
    },
    "security": {
        "password_min_length": 12,
        "session_timeout": 1800,
        "jwt_secret_env": "JWT_SECRET_KEY",
        "session_secret_env": "SESSION_SECRET_KEY",
        "developer_secret_env": "DEVELOPER_SECRET_KEY"
    },
    "developer": {
        "enabled": false,
        "debug_mode": false,
        "console_enabled": false
    }
}
