[run]
# Store coverage data under temp/ so stale/corrupted .coverage files in the repo
# root won't break pytest-cov runs.
data_file = temp/.coverage

# Keep coverage focused on the headless/runtime-critical modules that have
# executable tests in CI by omitting UI/desktop stacks and experimental
# subsystems. This avoids inflating denominators with code paths that are not
# executed in headless environments.
omit =
    src/ui/*
    src/analytics/*
    src/ai/*
    src/backend/*
    src/contracts/*
    src/performance/*
    src/product/*
    src/visualization/*
    src/mobile/*
    src/plugins/*
    src/voice/*

# Explicitly scope measurement and reporting to headless-critical modules that
# have CI coverage. This keeps the gate meaningful without pulling in UI-only
# stacks.
include =
    src/api/server.py
    src/api/middleware.py
    src/core/config_loader.py
    src/core/startup_preflight.py
    src/core/build_info.py
    src/utils/config.py
    src/utils/logger.py
    src/storage/json_store.py

[report]
include =
    src/api/server.py
    src/api/middleware.py
    src/core/config_loader.py
    src/core/startup_preflight.py
    src/core/build_info.py
    src/utils/config.py
    src/utils/logger.py
    src/storage/json_store.py
