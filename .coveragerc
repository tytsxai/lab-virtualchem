[run]
# Store coverage data under temp/ so stale/corrupted .coverage files in the repo
# root won't break pytest-cov runs.
data_file = temp/.coverage

# Keep coverage focused on the headless/runtime-critical modules that have
# executable tests in CI. UI/desktop stacks and experimental subsystems are
# excluded to avoid inflating denominators with code paths that are not run in
# headless environments.
include =
    */src/api/server.py
    */src/api/middleware.py
    */src/core/config_loader.py
    */src/core/startup_preflight.py
    */src/core/build_info.py
    */src/utils/config.py
    */src/utils/logger.py
    */src/storage/json_store.py

# Exclude large, UI-heavy, or optional modules from the CI coverage gate.
# The CI job already skips UI tests; omitting these keeps coverage focused on
# API/core/storage/security paths that are exercised in headless environments.
omit =
    src/ui/*
    src/analytics/*
    src/ai/*
    src/backend/*
    src/contracts/*
    src/performance/*
    src/product/*
    src/visualization/*
    src/mobile/*
    src/plugins/*
    src/voice/*
