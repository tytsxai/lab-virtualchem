# Git Attributes for VirtualChemLab
# 确保在不同操作系统上保持一致的行尾符和文件处理

# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.py text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf
*.pxi text eol=lf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Shell scripts (must use LF on all platforms)
*.sh text eol=lf
*.bash text eol=lf

# Batch scripts (must use CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf
.gitkeep text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary

# Archives
*.zip binary
*.7z binary
*.tar binary
*.gz binary
*.rar binary

# Python compiled
*.pyc binary
*.pyo binary
*.pyd binary
*.so binary
*.dll binary
*.dylib binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary

# Language statistics (告诉 GitHub 正确识别项目语言)
*.py linguist-detectable=true
*.md linguist-documentation
docs/** linguist-documentation
archive/** linguist-vendored
examples/** linguist-documentation

# Large files (Git LFS - 如果需要)
# *.psd filter=lfs diff=lfs merge=lfs -text
# *.ai filter=lfs diff=lfs merge=lfs -text


